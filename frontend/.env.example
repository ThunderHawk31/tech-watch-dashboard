# ============================================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================================
# Copier ce fichier en .env et remplir avec vos vraies valeurs

# Backend API URL (Railway webhook)
# Exemple: https://your-project.up.railway.app/webhook/api/articles
REACT_APP_BACKEND_URL=https://your-backend-url.railway.app/webhook/api/articles

# WebSocket pour développement (Vercel)
WDS_SOCKET_PORT=443

# Host pour développement
HOST=0.0.0.0

# Features flags
REACT_APP_ENABLE_VISUAL_EDITS=false
ENABLE_HEALTH_CHECK=false
