# ============================================================
# BACKEND ENVIRONMENT VARIABLES - VERSION SECURISEE
# ============================================================
# Copier ce fichier en .env et remplir avec vos vraies valeurs
# IMPORTANT: Ne JAMAIS committer le fichier .env

# MongoDB
MONGO_URL=REMPLACER_PAR_URL_MONGODB
DB_NAME=techwatch_db

# JWT Authentication
# Generer avec: python -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET_KEY=REMPLACER_PAR_SECRET_GENERE_64_CARACTERES

# N8N API Key (protection webhook)
# Generer avec: python -c 'import secrets; print(secrets.token_urlsafe(32))'
N8N_API_KEY=REMPLACER_PAR_API_KEY_GENEREE

# CORS (liste explicite, PAS de wildcard *)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Environment (development | production)
ENVIRONMENT=production
